{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "crush",
    "version": "0.1.7",
    "identifier": "com.mally.crush",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../build"
    },
    "app": {
        "windows": [
            {
                "label": "crushBoostrapChoiceWindow",
                "title": "crushBoostrapChoiceWindow",
                "width": 500,
                "height": 250,
                "url": "/mainWin/choiceWin",
                "decorations": false,
                "center": true,
                "transparent": true
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": ["$APPDATA/**"]
            }
        }
    },
    "bundle": {
        "createUpdaterArtifacts": true,
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": [
            "./resources/**/*.png",
            "./resources/locales/**/*.json",

            "./resources/tortellini.jpg"
        ]
    },
    "plugins": {
        "deep-link": {
            "desktop": {
                "schemes": ["roblox", "roblox-player"]
            }
        },
        "updater": {
            "endpoints": [
                "https://github.com/TheMallyGuy/crush/releases/latest/download/updater.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyN0YwRjJCNjJCM0FEQzcKUldUSHJiTmlLdzkvZ2dCMlY2Y3RUNmdyaHhXUzQ1VTNaOERPOUZzNkY1R0JFN3ZTL0tIM1doNWYK",
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
