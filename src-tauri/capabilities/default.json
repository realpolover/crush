{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": [
        "crushBoostrapChoiceWindow",
        "CrushMainWindow",
        "CrushHello"
    ],
    "permissions": [
        "core:default",
        "fs-pro:default",
        "opener:default",
        "updater:allow-check",
        "updater:allow-download-and-install",
        {
            "identifier": "opener:allow-open-url",
            "allow": [
                {
                    "url": "https://discord.gg/EwhG5y5Yw9"
                }
            ]
        },
        "os:default",
        "dialog:default",
        "dialog:allow-open",
        "clipboard-manager:allow-write-text",
        "store:default",
        "core:window:default",
        "core:window:allow-close",
        "core:window:allow-minimize",
        "core:window:allow-toggle-maximize",
        "core:window:allow-start-dragging",
        "core:window:allow-set-size",
        "core:window:allow-center",
        "core:window:allow-show",
        {
            "identifier": "http:default",
            "allow": [
                {
                    "url": "https://setup-ak.rbxcdn.com"
                },
                {
                    "url": "https://setup-cfly.rbxcdn.com"
                },
                {
                    "url": "https://setup-aws.rbxcdn.com"
                },
                {
                    "url": "https://games.roblox.com/"
                },
                {
                    "url": "https://thumbnails.roblox.com/"
                },
                {
                    "url": "https://apis.roblox.com/"
                },
                {
                    "url": "http://ip-api.com/json"
                },
                {
                    "url": "https://apis.rovalra.com/"
                }
            ],
            "deny": [
                {
                    "url": "https://placeholder.com"
                }
            ]
        },
        "log:default",
        "fs:default",
        "opener:allow-open-path",
        {
            "identifier": "fs:allow-mkdir",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" },
                { "path": "$CACHE/**" }
            ]
        },
        {
            "identifier": "fs:allow-copy-file",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" },
                { "path": "$CACHE/**" }
            ]
        },
        {
            "identifier": "fs:allow-remove",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" },
                { "path": "$CACHE/**" }
            ]
        },
        {
            "identifier": "fs:allow-read-file",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" },
                { "path": "$CACHE/**" },
                { "path": "$HOME/**" },
                { "path": "$DOCUMENT/**" },
                { "path": "$DOWNLOAD/**" },
                { "path": "$DESKTOP/**" },
                { "path": "**" }
            ]
        },
        {
            "identifier": "fs:allow-read-text-file",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" },
                { "path": "$CACHE/**" },
                { "path": "$RESOURCE/**" }
            ]
        },
        {
            "identifier": "fs:allow-write-text-file",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" },
                { "path": "$CACHE/**" }
            ]
        },
        {
            "identifier": "fs:allow-write-file",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" },
                { "path": "$CACHE/**" }
            ]
        },
        {
            "identifier": "opener:allow-open-path",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" }
            ]
        },
        {
            "identifier": "fs:allow-exists",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" },
                { "path": "$CACHE/**" },
                { "path": "**" }
            ]
        },
        {
            "identifier": "fs:allow-read-dir",
            "allow": [
                { "path": "$APPDATA/**" },
                { "path": "$LOCALDATA/**" },
                { "path": "$CACHE/**" }
            ]
        },
        "notification:default"
    ]
}